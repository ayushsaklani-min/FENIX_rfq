# ─── DATABASE ────────────────────────────────────────────────────────────────
# Use PostgreSQL in production. SQLite only for local dev.
DATABASE_URL="postgresql://user:password@localhost:5432/sealrfq"
# DATABASE_URL="file:./dev.db"   # local SQLite fallback

# ─── AUTH ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET="replace-with-a-strong-secret-min-32-chars"
ACCESS_TOKEN_TTL=900        # 15 minutes
REFRESH_TOKEN_TTL=604800    # 7 days

# ─── ENVIRONMENT ──────────────────────────────────────────────────────────────
NODE_ENV=production

# ─── FHENIX EVM CONTRACTS ───────────────────────────────────────────────────────
FHENIX_BACKEND_ENABLED=true
FHENIX_RPC_URL=https://api.testnet.fhenix.zone:7747
FHENIX_CHAIN_ID=42069
FHENIX_PRIVATE_KEY=0xyourprivatekey
FHENIX_SEAL_RFQ_ADDRESS=0x0000000000000000000000000000000000000000
FHENIX_SEAL_VICKREY_ADDRESS=0x0000000000000000000000000000000000000000
FHENIX_SEAL_DUTCH_ADDRESS=0x0000000000000000000000000000000000000000
FHENIX_SEAL_INVOICE_ADDRESS=0x0000000000000000000000000000000000000000

# ─── REDIS (required in production for rate limiting) ─────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AUDITOR WHITELIST ────────────────────────────────────────────────────────
# Comma-separated EVM addresses that receive the AUDITOR role on login.
# Example: AUDITOR_WHITELIST="0xabc...xyz,0xdef...uvw"
AUDITOR_WHITELIST=""
