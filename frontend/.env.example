# ─── FHENIX CONTRACT ─────────────────────────────────────────────────────────
#
# Primary contract addresses on Fhenix network
# Deployed contracts:
#   SealRFQ - Main RFQ contract with FHE encrypted bids
#   SealVickrey - Sealed-bid second-price auction
#   SealDutch - Dutch descending-price auction
#   SealInvoice - Invoice/payment contract
#
NEXT_PUBLIC_FHENIX_RFQ_ADDRESS=0x0000000000000000000000000000000000000001
NEXT_PUBLIC_FHENIX_VICKREY_ADDRESS=0x0000000000000000000000000000000000000002
NEXT_PUBLIC_FHENIX_DUTCH_ADDRESS=0x0000000000000000000000000000000000000003
NEXT_PUBLIC_FHENIX_INVOICE_ADDRESS=0x0000000000000000000000000000000000000004
NEXT_PUBLIC_FHENIX_CHAIN_ID=42069
NEXT_PUBLIC_FHENIX_RPC_URL=https://rpc.fhenix.zone
NEXT_PUBLIC_FHENIX_EXPLORER_URL=https://explorer.fhenix.zone

# ─── BACKEND ──────────────────────────────────────────────────────────────────
# Server-side only — used by frontend API proxy routes.
BACKEND_API_URL=http://localhost:3000
