{
  "name": "fhenix-sealrfq",
  "version": "1.0.0",
  "description": "Privacy-preserving procurement platform on Fhenix using FHE",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "deploy:local": "npx hardhat run scripts/deploy.js --network localhost",
    "deploy:sepolia": "npx hardhat run scripts/deploy.ts --network eth-sepolia",
    "test:eth-sepolia": "npx hardhat test test/integration/sepolia/SealDutch.sepolia.test.ts test/integration/sepolia/SealInvoice.sepolia.test.ts test/integration/sepolia/SealRFQ.sepolia.test.ts test/integration/sepolia/SealVickrey.sepolia.test.ts --network eth-sepolia",
    "deploy:testnet": "npm run deploy:sepolia"
  },
  "devDependencies": {
    "@cofhe/hardhat-plugin": "^0.4.0",
    "@cofhe/sdk": "^0.4.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.19.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@fhenixprotocol/cofhe-contracts": "0.1.3",
    "@fhenixprotocol/contracts": "^0.3.1",
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^17.3.1",
    "fhenix-confidential-contracts": "^0.2.1"
  }
}
